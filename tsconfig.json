{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": false,
    "resolveJsonModule": false,
    "isolatedModules": true,
    "allowImportingTsExtensions": false,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "index.d.ts",
    "tests/types/**/*.ts"
  ]
}
